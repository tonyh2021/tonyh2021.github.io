# Canonical site origin — no trailing slash.
# Used for metadataBase, Open Graph / Twitter URLs, canonical links, sitemap.xml,
# robots.txt, and article JSON-LD.
#
# --- Local ---
NEXT_PUBLIC_SITE_URL=http://localhost:3000
#
# --- GitHub Pages (production) ---
# User/org site (username.github.io repo):
# NEXT_PUBLIC_SITE_URL=https://tonyh2021.github.io
#
# Project site (repo name ≠ username.github.io), pages under /repo/:
# NEXT_PUBLIC_SITE_URL=https://tonyh2021.github.io/tonyh2021
# NEXT_PUBLIC_BASE_PATH=/tonyh2021
